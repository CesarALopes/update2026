@model IEnumerable<SalesWebMvc.Models.Seller>

@{

    ViewData["Title"] = "Sellers";

}

<h1>@ViewData["Title"]</h1>

<table class="table table table-striped table-hover">

    <thead class ="table-dark" style="--bs-table-bg: #67b6e0;">

        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>

       
            <th>
               @Html.DisplayNameFor(model => model.BirthDate)
            </th>
        
      
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
       

        
            <th>
                @Html.DisplayNameFor(model => model.BaseSalary)
            </th>
            <th></th>
        </tr>

    </thead>

    <tbody>

        @foreach (var x in Model)
        {
            <tr>

                <td>

                    @Html.DisplayFor(model => x.Name)

                </td>

             
   

                <td>

                    @Html.DisplayFor(model => x.BirthDate)

                </td>

            

                <td>

                    @Html.DisplayFor(model => x.Email)

                </td>

           

                <td>

                    @Html.DisplayFor(model => x.BaseSalary) 

                </td>
                <td>

                    <a asp-action="Edit" asp-route-id="@x.Id">Edit</a>
                    <a asp-action="Details" asp-route-id="@x.Id">Details</a>
                    <a asp-action="Delete" asp-route-id="@x.Id">Delete</a>
                </td>
            </tr>
           
        }

    </tbody>

</table>